local isDesyncing = false

local function setReady()
    isDesyncing = false
    btnLabel.Text = "DESYNC"
    btnLabel.TextColor3 = C.BtnText
    statusText.Text = "Ready"
    statusText.TextColor3 = C.StatusOk
    TweenService:Create(btn, tFast, {BackgroundColor3 = C.BtnIdle}):Play()
    TweenService:Create(btnStroke, tFast, {Color = C.BtnBorder, Transparency = 0.2}):Play()
    TweenService:Create(btnGlow, tFast, {ImageColor3 = C.Purple, ImageTransparency = 0.85}):Play()
end

btn.MouseEnter:Connect(function()
    if isDesyncing then return end
    TweenService:Create(btn, tFast, {BackgroundColor3 = C.BtnHover}):Play()
    TweenService:Create(btnStroke, tFast, {Transparency = 0}):Play()
    TweenService:Create(btnGlow, tFast, {ImageTransparency = 0.75}):Play()
end)

btn.MouseLeave:Connect(function()
    if isDesyncing then return end
    TweenService:Create(btn, tFast, {BackgroundColor3 = C.BtnIdle}):Play()
    TweenService:Create(btnStroke, tFast, {Transparency = 0.2}):Play()
    TweenService:Create(btnGlow, tFast, {ImageTransparency = 0.85}):Play()
end)

btn.MouseButton1Click:Connect(function()
    if isDesyncing then return end
    isDesyncing = true

    TweenService:Create(btn, tFast, {BackgroundColor3 = C.BtnPress}):Play()
    TweenService:Create(btnStroke, tFast, {Color = C.Yellow, Transparency = 0}):Play()
    TweenService:Create(btnGlow, tFast, {ImageColor3 = C.Yellow, ImageTransparency = 0.75}):Play()
    btnLabel.Text = "DESYNCING"
    btnLabel.TextColor3 = C.Yellow
    statusText.Text = "DESYNCING"
    statusText.TextColor3 = C.StatusWrn

    local respawned = false

    local charConn
    charConn = lp.CharacterAdded:Connect(function(newChar)
        charConn:Disconnect()
        respawned = true
        newChar:WaitForChild("Humanoid")
        task.wait(0.5)
        setReady()
    end)

    local char = lp.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Health = -math.huge
        end
    end

    statusText.Text = "Waiting..."
    task.wait(0.3)
    raknet.desync(true)

    task.spawn(function()
        local waited = 0
        while not respawned and waited < 15 do
            task.wait(0.25)
            waited += 0.25
        end
        if not respawned then
            if charConn.Connected then charConn:Disconnect() end
            setReady()
        end
    end)
end)

