local function make(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function rc(parent, r)
    return make("UICorner", {CornerRadius = UDim.new(0, r), Parent = parent})
end

local function rs(parent, color, thick, t)
    return make("UIStroke", {Color = color, Thickness = thick or 1, Transparency = t or 0, Parent = parent})
end

local function showNotification(msg, duration)
    for _, g in pairs(playerGui:GetChildren()) do
        if g.Name == "ExotixzzHubNotify" then g:Destroy() end
    end
    local ng = make("ScreenGui", {
        Name = "ExotixzzHubNotify", ResetOnSpawn = false,
        DisplayOrder = 1000, ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = playerGui
    })
    local bar = make("Frame", {
        Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = C.RedBg, BorderSizePixel = 0, Parent = ng
    })
    rs(bar, C.RedBorder, 1, 0.3)
    make("TextLabel", {
        Size = UDim2.new(0, 36, 1, 0), Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1, Text = "!", TextColor3 = C.Red,
        TextSize = 18, Font = Enum.Font.GothamBold, Parent = bar
    })
    make("TextLabel", {
        Size = UDim2.new(1, -56, 1, 0), Position = UDim2.new(0, 48, 0, 0),
        BackgroundTransparency = 1, Text = msg, TextColor3 = Color3.fromRGB(230, 180, 180),
        TextSize = 13, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, Parent = bar
    })
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 2), Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = C.Red, BackgroundTransparency = 0.4,
        BorderSizePixel = 0, Parent = bar
    })
    TweenService:Create(bar, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = UDim2.new(1, 0, 0, 42)
    }):Play()
    task.delay(duration or 5, function()
        local out = TweenService:Create(bar, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(1, 0, 0, 0)
        })
        out.Completed:Connect(function() ng:Destroy() end)
        out:Play()
    end)
end

