    end
end)

local function onChar(char)
    State.Running = false
    stealBtn.Text = "STEAL"
    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        hum.Died:Connect(function()
            State.Running = false
            stealBtn.Text = "STEAL"
        end)
    end
end
