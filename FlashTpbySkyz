local function setStatus(txt, col)
    statusLbl.Text      = txt
    statusLbl.TextColor3 = col or COL_GREY
    task.delay(3, function()
        if statusLbl.Text == txt then
            statusLbl.Text       = "Ready  [" .. State.Keybind.Name .. "] to TP"
            statusLbl.TextColor3 = COL_GREY
        end
    end)
end

local function getClosest()
    local myR = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not myR then return nil end
    local best, bd = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            if r then
                local d = (myR.Position - r.Position).Magnitude
                if d < bd then bd = d; best = p end
            end
        end
    end
    return best
end

local blockCooldown = false
local function doBlock()
    if blockCooldown then return end
    blockCooldown = true
    local tgt = getClosest()
    if not tgt then
        setStatus("No nearby player", Color3.fromRGB(255,100,100))
        blockCooldown = false
        return
    end
    pcall(function() StarterGui:SetCore("PromptBlockPlayer", tgt) end)
    task.wait(0.4)
    local vp = Camera.ViewportSize
    for i = 1, 2 do
        VirtualInputManager:SendMouseButtonEvent(vp.X/2, vp.Y*0.54, 0, true,  game, 1); task.wait(0.02)
        VirtualInputManager:SendMouseButtonEvent(vp.X/2, vp.Y*0.54, 0, false, game, 1); task.wait(0.05)
    end
    setStatus("Player blocked!", Color3.fromRGB(80,255,80))
    task.wait(2)
    blockCooldown = false
end

local function fastTeleport(position)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(position)
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end
end

local function equip(char, hum, n)
    local t = Player.Backpack:FindFirstChild(n) or char:FindFirstChild(n)
    if t then hum:EquipTool(t); return t end
    for _, v in pairs(Player.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(n:lower()) then
            hum:EquipTool(v); return v
        end
    end
    return nil
end

local function RunPath()
    if State.Running then return end
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChild("Humanoid")
    if not root or not hum then setStatus("No character", Color3.fromRGB(255,100,100)); return end

    State.Running = true
    stealBtn.Text      = "RUNNING..."
    stealBtn.TextColor3 = Color3.fromRGB(0, 0, 0)

    task.spawn(function()
        for i = 1, #CFG.Waypoints do
            if not State.Running or Player.Character ~= char then break end
            fastTeleport(CFG.Waypoints[i])
            setStatus("TP " .. i .. "/" .. #CFG.Waypoints, Color3.fromRGB(255,200,50))
            task.wait(CFG.TpDelay)
        end

        if State.InvisFinish and State.Running then
            task.wait(CFG.SafetyDelay)
            local cloak = Player.Backpack:FindFirstChild(CFG.InvisTool)
            if cloak then hum:EquipTool(cloak); cloak:Activate() end
        end

        State.Running = false
        stealBtn.Text       = "STEAL"
        stealBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        setStatus("TP Complete!", Color3.fromRGB(80,255,80))
    end)
end

local function doFlashTP()
    local char = Player.Character
    if not char then setStatus("No character", Color3.fromRGB(255,100,100)); return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    task.spawn(function()
        local ok, err = pcall(function()

            hrp.CFrame = CFrame.new(CFG.POS_CARPET)
            local carpet = equip(char, hum, "Carpet")
            if carpet then
                local t0 = tick()
                repeat task.wait(0.02) until char:FindFirstChild("Carpet") or tick()-t0 > 0.8
                pcall(function() carpet:Activate() end)
                task.wait(0.15)
            end

            local flash = equip(char, hum, "Flash")
            if not flash then
                setStatus("No Flash found", Color3.fromRGB(255,100,100))
                return
            end

            local t1 = tick()
            repeat task.wait(0.02) until char:FindFirstChild("Flash") or tick()-t1 > 1

            hrp.CFrame = CFrame.new(
                CFG.POS_CARPET,
                Vector3.new(CFG.POS_FLASH_TARGET.X, CFG.POS_CARPET.Y, CFG.POS_FLASH_TARGET.Z)
            )
            task.wait(0.06)

            local flashInChar = char:FindFirstChild("Flash")
            if flashInChar then
                pcall(function() flashInChar:Activate() end)
            else

                local vp = Camera.ViewportSize
                VirtualInputManager:SendMouseButtonEvent(math.floor(vp.X/2), math.floor(vp.Y/2), 0, true,  game, 1)
                task.wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(math.floor(vp.X/2), math.floor(vp.Y/2), 0, false, game, 1)
            end

            task.wait(0.1)
            setStatus("Flash TP done!", Color3.fromRGB(255,150,50))
        end)

        if not ok then
            setStatus("Flash TP error", Color3.fromRGB(255,100,100))
            warn("[ExotixzzHub] doFlashTP: " .. tostring(err))
        end
    end)
end

local function toggle(key, btn, onLabel, offLabel, onFn, offFn)
    State[key] = not State[key]
    local on = State[key]
    btn.Text       = on and onLabel or offLabel
    btn.TextColor3 = on and COL_ON or COL_OFF
    if on and onFn then onFn() end
    if not on and offFn then offFn() end
end

