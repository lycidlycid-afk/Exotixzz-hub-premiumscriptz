local function mkRow(labelText, yPos, textColor, clickFn)
    local row = Instance.new("TextButton", main)
    row.Size             = UDim2.new(1, -16, 0, 28)
    row.Position         = UDim2.fromOffset(8, yPos)
    row.BackgroundColor3 = COL_BTN
    row.Text             = labelText
    row.Font             = Enum.Font.GothamBold
    row.TextSize         = 12
    row.TextColor3       = textColor
    row.AutoButtonColor  = false
    row.BorderSizePixel  = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)
    local s = Instance.new("UIStroke", row)
    s.Color = Color3.fromRGB(35, 35, 35); s.Thickness = 1
    row.MouseEnter:Connect(function()
        TweenService:Create(row, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(28,28,28)}):Play()
    end)
    row.MouseLeave:Connect(function()
        TweenService:Create(row, TweenInfo.new(0.12), {BackgroundColor3 = COL_BTN}):Play()
    end)
    if clickFn then row.MouseButton1Click:Connect(clickFn) end
    return row
end

